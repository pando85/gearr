{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
  ],
  packageRules: [
    {
      commitMessagePrefix: 'build(deps): ',
      matchPackageNames: [
        '/.*/',
      ],
    },
    {
      matchUpdateTypes: [
        'minor',
      ],
      matchCurrentVersion: '!/^0/',
      automerge: true,
      automergeType: 'pr',
      platformAutomerge: true,
    },
    {
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
      automergeType: 'pr',
      platformAutomerge: true,
    },
    {
      matchPackageNames: [
        'fork-ts-checker-webpack-plugin',
      ],
      allowedVersions: '<9.0.0',
    },
  ],
}