{
  "extends": [
    "@commitlint/config-conventional"
  ],
  "rules": {
    "type-enum": [
      0,
      "always",
      []
    ],
    "scope-enum": [
      0,
      "always",
      []
    ],
    "subject-case": [
      0,
      "always",
      []
    ],
    "body-leading-blank": [
      2,
      "always"
    ],
    "footer-leading-blank": [
      2,
      "always"
    ]
  }
}